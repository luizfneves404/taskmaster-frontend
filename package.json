{
	"name": "taskmaster-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite",
		"build": "tsc && bunx --bun vite build",
		"lint": "oxlint",
		"preview": "bunx --bun vite preview",
		"generate:api": "(cd ../Taskmaster-Backend && uv run manage.py spectacular --format openapi-json) > src/api/openapi.json && openapi-typescript src/api/openapi.json -o src/api/schema.d.ts"
	},
	"dependencies": {
		"openapi-fetch": "^0.17.0"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"openapi-typescript": "^7.13.0",
		"oxlint": "^1.69.0",
		"typescript": "~6.0.2",
		"vite": "^8.1.0"
	}
}
